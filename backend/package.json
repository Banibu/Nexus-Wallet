{
  "name": "nexus-wallet-backend",
  "version": "1.0.0",
  "description": "Nexus Crypto Wallet API - Fastify + Prisma + Redis",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:generate": "node scripts/prisma.js generate",
    "prisma:migrate": "node scripts/prisma.js migrate deploy",
    "prisma:push": "node scripts/prisma.js db push",
    "seed": "tsx prisma/seed.ts",
    "poc": "tsx scripts/poc.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "proxy": "tsx watch src/proxy.ts",
    "proxy:start": "node dist/proxy.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/http-proxy": "^11.5.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^9.1.3",
    "@prisma/client": "^5.22.0",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "pino-pretty": "^11.2.2",
    "uuid": "^14.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.16.10",
    "@types/uuid": "^9.0.8",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.1.9"
  }
}
