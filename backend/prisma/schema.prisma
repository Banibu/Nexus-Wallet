// Prisma schema for Nexus Crypto Wallet
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  wallet        Wallet?
  refreshTokens RefreshToken[]
  transactions  Transaction[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  balances  Balance[]
  movements Movement[]

  @@map("wallets")
}

model Balance {
  id       String  @id @default(uuid())
  walletId String
  token    String
  amount   Decimal @default(0) @db.Decimal(38, 18)

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, token])
  @@index([walletId])
  @@map("balances")
}

enum MovementType {
  DEPOSIT
  SWAP_IN
  SWAP_OUT
  SWAP_FEE
  WITHDRAWAL
}

enum TransactionType {
  DEPOSIT
  SWAP
  WITHDRAWAL
}

model Movement {
  id            String       @id @default(uuid())
  walletId      String
  type          MovementType
  token         String
  amount        Decimal      @db.Decimal(38, 18) // signed: positive = credit, negative = debit
  balanceBefore Decimal      @db.Decimal(38, 18)
  balanceAfter  Decimal      @db.Decimal(38, 18)
  transactionId String?
  createdAt     DateTime     @default(now())

  wallet      Wallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([walletId, createdAt])
  @@index([walletId, token, createdAt])
  @@index([transactionId])
  @@map("movements")
}

model Transaction {
  id             String          @id @default(uuid())
  userId         String
  type           TransactionType
  // For DEPOSIT: tokenTo + amountTo set, others null
  // For SWAP: tokenFrom, amountFrom, tokenTo, amountTo, feeAmount, feeToken, rate
  // For WITHDRAWAL: tokenFrom + amountFrom set
  tokenFrom      String?
  amountFrom     Decimal?        @db.Decimal(38, 18)
  tokenTo        String?
  amountTo       Decimal?        @db.Decimal(38, 18)
  feeAmount      Decimal?        @db.Decimal(38, 18)
  feeToken       String?
  rate           Decimal?        @db.Decimal(38, 18)
  idempotencyKey String?         @unique
  metadata       Json?
  createdAt      DateTime        @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  movements Movement[]

  @@index([userId, createdAt])
  @@index([type])
  @@map("transactions")
}
