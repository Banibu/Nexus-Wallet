PORT=8002
HOST=0.0.0.0
# Execution environment: "development" for local development, "production" for optimized deployment
NODE_ENV=development

# Database Configuration
POSTGRES_USER="seu_usuario_aqui"
POSTGRES_PASSWORD="sua_senha_segura_aqui"
POSTGRES_DB="nexus_wallet"

# URLs for local development (Docker Compose will automatically override these to use "db" and "redis")
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}?schema=public"
REDIS_URL="redis://127.0.0.1:6379"

# Frontend Configuration (Required since frontend and backend are decoupled)
REACT_APP_BACKEND_URL="http://localhost:8002"

# JWT Authentication Secrets
JWT_ACCESS_SECRET="default-dev-access-token-secret-nexus-wallet-key"
JWT_REFRESH_SECRET="default-dev-refresh-token-secret-nexus-wallet-key"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=7

# CoinGecko API Configuration
COINGECKO_API_KEY="SUA_CHAVE_AQUI"
COINGECKO_BASE_URL="https://api.coingecko.com/api/v3"

# Swap configuration
SWAP_FEE_PERCENT=1.5

# Webhooks
WEBHOOK_SECRET="secret_para_webhooks_aqui"
